<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar') %>

    <div class="app-main app-main--single">
      <header class="mobile-header">
        <a href="<%= typeof redirect !== 'undefined' ? redirect : '/feed' %>" class="text-muted"><i class="fas fa-arrow-left"></i></a>
        <h1 style="font-size:1rem">Edit post</h1>
        <span></span>
      </header>

      <div class="content-primary page-padding">
        <div class="card compose-card" style="max-width:520px;margin:2rem auto">
          <form action="/update/<%= post._id %>" method="post" enctype="multipart/form-data">
            <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '/feed' %>">
            <textarea name="content" maxlength="2200" required><%= post.content %></textarea>
            <% if (post.image) { %>
            <div style="margin-bottom:1rem">
              <img src="/images/uploads/<%= encodeURIComponent(post.image) %>" alt="" style="max-height:200px;border-radius:8px;width:100%;object-fit:cover">
              <label style="display:flex;align-items:center;gap:0.5rem;margin-top:0.5rem;font-size:0.85rem;color:var(--text-muted)">
                <input type="checkbox" name="removeImage" value="1"> Remove photo
              </label>
            </div>
            <% } %>
            <label class="compose-actions" style="margin-bottom:1rem">
              <i class="far fa-image"></i>
              <span><%= post.image ? 'Replace photo' : 'Add photo' %></span>
              <input type="file" name="image" accept="image/*" style="display:none">
            </label>
            <div class="compose-actions">
              <a href="<%= typeof redirect !== 'undefined' ? redirect : '/feed' %>" class="btn btn-secondary">Cancel</a>
              <button type="submit" class="btn btn-primary" style="width:auto;margin:0">Save changes</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <%- include('partials/bottom-nav') %>
  </div>
  <script src="/javascripts/app.js"></script>
</body>
</html>
