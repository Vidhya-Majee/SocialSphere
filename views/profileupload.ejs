<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar') %>

    <div class="app-main app-main--single">
      <header class="mobile-header">
        <a href="/profile"><i class="fas fa-arrow-left"></i></a>
        <h1 style="font-size:1rem">Change photo</h1>
        <span></span>
      </header>

      <div class="content-primary page-padding" style="text-align:center;padding-top:2rem">
        <img class="avatar avatar-xl" style="margin:0 auto 1.5rem" src="<%= profileImg(user.profilepic) %>" alt="">
        <div class="card compose-card" style="max-width:400px;margin:0 auto">
          <form action="/upload" method="post" enctype="multipart/form-data">
            <label class="btn btn-secondary" style="width:100%;cursor:pointer;margin-bottom:1rem">
              <i class="fas fa-camera"></i> Choose from gallery
              <input type="file" name="image" accept="image/*" required style="display:none">
            </label>
            <button type="submit" class="btn btn-primary">Update profile photo</button>
          </form>
        </div>
      </div>
    </div>

    <%- include('partials/bottom-nav') %>
  </div>
  <script src="/javascripts/app.js"></script>
</body>
</html>
