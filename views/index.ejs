<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body data-theme="light">
  <div class="auth-page">
    <section class="auth-showcase" aria-hidden="true">
      <div class="auth-showcase-inner">
        <h1>Share moments that matter.</h1>
        <p>Join millions on SocialSphere — photos, stories, and real connections on every device.</p>
        <div class="auth-features">
          <div class="auth-feature"><i class="fas fa-mobile-screen"></i> Works on phone, tablet & laptop</div>
          <div class="auth-feature"><i class="fas fa-heart"></i> Like, comment & follow friends</div>
          <div class="auth-feature"><i class="fas fa-compass"></i> Explore trending creators</div>
          <div class="auth-feature"><i class="fas fa-shield-halved"></i> Your data stays yours</div>
        </div>
      </div>
    </section>

    <section class="auth-panel">
      <div class="auth-card">
        <div class="auth-logo">
          <div class="auth-logo-icon"><i class="fas fa-globe"></i></div>
          <h2>SocialSphere</h2>
          <span>Sign up to see photos and videos from friends.</span>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-error"><%= error %></div>
        <% } %>

        <form action="/register" method="post">
          <div class="form-group">
            <input class="form-input" type="text" name="name" placeholder="Full name" required
              value="<%= typeof values !== 'undefined' && values.name ? values.name : '' %>">
          </div>
          <div class="form-group">
            <input class="form-input" type="text" name="username" placeholder="Username" required
              pattern="[a-zA-Z0-9._]{3,30}" title="3–30 characters: letters, numbers, . _"
              value="<%= typeof values !== 'undefined' && values.username ? values.username : '' %>">
          </div>
          <div class="form-group">
            <input class="form-input" type="email" name="email" placeholder="Email" required
              value="<%= typeof values !== 'undefined' && values.email ? values.email : '' %>">
          </div>
          <div class="form-group">
            <input class="form-input" type="password" name="password" placeholder="Password" required minlength="6">
          </div>
          <div class="form-group">
            <input class="form-input" type="number" name="age" placeholder="Age" min="13" max="120"
              value="<%= typeof values !== 'undefined' && values.age ? values.age : '' %>">
          </div>
          <button type="submit" class="btn btn-primary">Sign up</button>
        </form>

        <p class="auth-footer">
          Have an account? <a href="/login">Log in</a>
        </p>
      </div>
      <p class="auth-footer" style="margin-top:1.5rem;max-width:380px">
        By signing up, you agree to our Terms and Privacy Policy.
      </p>
    </section>
  </div>
  <script src="/javascripts/app.js"></script>
</body>
</html>
