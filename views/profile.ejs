<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar') %>

    <div class="app-main app-main--single">
      <header class="mobile-header">
        <h1><%= profileUser.username %></h1>
        <% if (isOwn) { %>
        <button type="button" class="settings-trigger" id="profileSettingsBtn" aria-label="Settings">
          <i class="fas fa-gear"></i>
        </button>
        <% } %>
      </header>

      <div class="content-primary page-padding">
        <section class="profile-header">
          <div class="profile-top">
            <img class="avatar avatar-xl" src="<%= profileImg(profileUser.profilepic) %>" alt="<%= profileUser.username %>">
          </div>
          <div style="flex:1">
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.75rem;flex-wrap:wrap">
              <h2 style="font-size:1.25rem;font-weight:300"><%= profileUser.username %></h2>
              <% if (isOwn) { %>
              <button type="button" class="settings-trigger desktop-settings-btn" id="profileSettingsBtnDesktop" aria-label="Settings">
                <i class="fas fa-gear"></i>
              </button>
              <% } %>
              <div class="profile-actions">
                <% if (isOwn) { %>
                <a href="/profile/upload" class="btn btn-secondary hidden-mobile">Edit photo</a>
                <% } else { %>
                <a href="/messages/with/<%= profileUser.username %>" class="btn btn-primary" style="width:auto;margin:0">
                  <i class="far fa-comment-dots"></i> Message
                </a>
                <a href="/follow/<%= profileUser._id %>?next=/u/<%= profileUser.username %>"
                   class="btn <%= isFollowing ? 'btn-secondary following' : 'btn-secondary' %>"
                   style="width:auto;margin:0">
                  <%= isFollowing ? 'Following' : 'Follow' %>
                </a>
                <% } %>
              </div>
            </div>

            <div class="profile-stats">
              <span><strong><%= profileUser.posts.length %></strong> posts</span>
              <span><strong><%= (profileUser.followers || []).length %></strong> followers</span>
              <span><strong><%= (profileUser.following || []).length %></strong> following</span>
              <% if (isOwn) { %>
              <span><strong><%= (profileUser.savedPosts || []).length %></strong> saved</span>
              <% } %>
            </div>

            <p class="profile-bio"><strong><%= profileUser.name %></strong></p>
            <% if (profileUser.bio) { %>
            <p class="profile-bio text-muted"><%= profileUser.bio %></p>
            <% } %>

            <% if (isOwn) { %>
            <form class="profile-bio-form" id="bio" action="/profile/bio" method="post">
              <textarea name="bio" placeholder="Write a bio..." maxlength="160"><%= profileUser.bio || '' %></textarea>
              <button type="submit" class="btn btn-secondary" style="width:auto">Save bio</button>
            </form>
            <% } %>
          </div>
        </section>

        <div class="profile-tabs">
          <span class="active"><i class="fas fa-table-cells"></i> Posts</span>
          <% if (isOwn) { %>
          <a href="/profile/saved"><i class="fas fa-bookmark"></i> Saved</a>
          <% } %>
        </div>

        <% if (!profileUser.posts.length) { %>
        <div class="empty-state">
          <i class="fas fa-camera"></i>
          <p><%= isOwn ? "When you share photos, they'll appear on your profile." : 'No posts yet.' %></p>
          <% if (isOwn) { %>
          <a href="/feed" class="text-link">Share your first post</a>
          <% } %>
        </div>
        <% } else { %>
        <div class="posts-grid">
          <% profileUser.posts.forEach(function(post) { %>
          <a href="/feed#post-<%= post._id %>" class="grid-post">
            <% if (post.image) { %>
            <img src="/images/uploads/<%= encodeURIComponent(post.image) %>" alt="">
            <% } else { %>
            <div class="grid-text"><%= post.content %></div>
            <% } %>
            <div class="grid-overlay">
              <span><i class="fas fa-heart"></i> <%= (post.likes || []).length %></span>
              <span><i class="fas fa-comment"></i> <%= (post.comments || []).length %></span>
            </div>
          </a>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>

    <%- include('partials/bottom-nav') %>
  </div>

  <% if (isOwn) { %>
  <!-- Profile Settings Sidebar -->
  <div class="profile-settings-overlay" id="profileSettingsOverlay"></div>
  <aside class="profile-settings-panel" id="profileSettingsPanel" aria-label="Settings">
    <div class="profile-settings-panel__head">
      <h2>Settings</h2>
      <button type="button" class="profile-settings-panel__close" id="closeProfileSettings" aria-label="Close">
        <i class="fas fa-xmark"></i>
      </button>
    </div>

    <div class="profile-settings-panel__user">
      <img class="avatar avatar-lg" src="<%= profileImg(profileUser.profilepic) %>" alt="<%= profileUser.username %>">
      <div>
        <strong><%= profileUser.username %></strong>
        <span class="text-muted"><%= profileUser.name %></span>
      </div>
    </div>

    <nav class="profile-settings-panel__nav">
      <a href="/profile/saved" class="ps-nav-item">
        <span class="ps-nav-icon"><i class="fas fa-bookmark"></i></span>
        <span class="ps-nav-text">
          <strong>Saved Posts</strong>
          <small><%= (profileUser.savedPosts || []).length %> saved</small>
        </span>
        <i class="fas fa-chevron-right"></i>
      </a>
      <a href="/profile/upload" class="ps-nav-item">
        <span class="ps-nav-icon"><i class="fas fa-camera"></i></span>
        <span class="ps-nav-text">
          <strong>Change Photo</strong>
          <small>Update profile picture</small>
        </span>
        <i class="fas fa-chevron-right"></i>
      </a>
      <a href="/profile#bio" class="ps-nav-item" id="psBioLink">
        <span class="ps-nav-icon"><i class="fas fa-pen"></i></span>
        <span class="ps-nav-text">
          <strong>Edit Bio</strong>
          <small>Update your bio</small>
        </span>
        <i class="fas fa-chevron-right"></i>
      </a>

      <div class="ps-nav-divider"></div>

      <a href="/feed" class="ps-nav-item">
        <span class="ps-nav-icon"><i class="fas fa-house"></i></span>
        <span class="ps-nav-text"><strong>Home</strong></span>
        <i class="fas fa-chevron-right"></i>
      </a>
      <a href="/messages" class="ps-nav-item">
        <span class="ps-nav-icon"><i class="far fa-comment-dots"></i></span>
        <span class="ps-nav-text"><strong>Messages</strong></span>
        <i class="fas fa-chevron-right"></i>
      </a>
      <a href="/explore" class="ps-nav-item">
        <span class="ps-nav-icon"><i class="fas fa-compass"></i></span>
        <span class="ps-nav-text"><strong>Explore</strong></span>
        <i class="fas fa-chevron-right"></i>
      </a>

      <div class="ps-nav-divider"></div>

      <button type="button" class="ps-nav-item" id="psThemeToggle">
        <span class="ps-nav-icon ps-nav-icon--theme"><i class="fas fa-moon" id="psThemeIcon"></i></span>
        <span class="ps-nav-text">
          <strong>Dark Mode</strong>
          <small id="psThemeLabel">Toggle theme</small>
        </span>
        <span class="ps-toggle" id="psToggleTrack">
          <span class="ps-toggle__dot"></span>
        </span>
      </button>
    </nav>

    <div class="profile-settings-panel__footer">
      <a href="/logout" class="ps-nav-item ps-nav-item--logout">
        <span class="ps-nav-icon ps-nav-icon--danger"><i class="fas fa-right-from-bracket"></i></span>
        <span class="ps-nav-text"><strong>Log Out</strong></span>
      </a>
    </div>
  </aside>

  <script>
    (function () {
      const panel = document.getElementById('profileSettingsPanel');
      const overlay = document.getElementById('profileSettingsOverlay');
      const closeBtn = document.getElementById('closeProfileSettings');
      const openBtn = document.getElementById('profileSettingsBtn');
      const openBtnDesktop = document.getElementById('profileSettingsBtnDesktop');
      const themeToggle = document.getElementById('psThemeToggle');
      const bioLink = document.getElementById('psBioLink');

      if (!panel) return;

      function openPanel() {
        panel.classList.add('open');
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
        updateThemeUI();
      }

      function closePanel() {
        panel.classList.remove('open');
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }

      function updateThemeUI() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const icon = document.getElementById('psThemeIcon');
        const label = document.getElementById('psThemeLabel');
        const track = document.getElementById('psToggleTrack');
        if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        if (label) label.textContent = isDark ? 'Light mode' : 'Dark mode';
        if (track) track.classList.toggle('active', isDark);
      }

      if (openBtn) openBtn.addEventListener('click', openPanel);
      if (openBtnDesktop) openBtnDesktop.addEventListener('click', openPanel);
      if (closeBtn) closeBtn.addEventListener('click', closePanel);
      if (overlay) overlay.addEventListener('click', closePanel);

      if (themeToggle) {
        themeToggle.addEventListener('click', function () {
          if (typeof toggleTheme === 'function') toggleTheme();
          updateThemeUI();
        });
      }

      if (bioLink) {
        bioLink.addEventListener('click', function (e) {
          e.preventDefault();
          closePanel();
          const bioForm = document.getElementById('bio');
          if (bioForm) {
            setTimeout(function () {
              bioForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
              var ta = bioForm.querySelector('textarea');
              if (ta) ta.focus();
            }, 350);
          }
        });
      }
    })();
  </script>
  <% } %>

  <script src="/javascripts/app.js"></script>
</body>
</html>
