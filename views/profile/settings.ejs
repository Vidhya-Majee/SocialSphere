<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <div class="app-shell">
    <%- include('../partials/sidebar') %>

    <div class="app-main app-main--single">
      <header class="mobile-header">
        <a href="/profile" class="text-muted"><i class="fas fa-arrow-left"></i></a>
        <h1 style="font-size:1rem">Settings</h1>
        <span></span>
      </header>

      <div class="content-primary page-padding settings-page">
        <div class="settings-profile-card">
          <img class="avatar avatar-lg" src="<%= profileImg(user.profilepic) %>" alt="">
          <div>
            <strong><%= user.username %></strong>
            <span class="text-muted"><%= user.name %></span>
          </div>
        </div>

        <nav class="settings-menu">
          <a href="/profile/saved" class="settings-item">
            <span class="settings-item__icon"><i class="fas fa-bookmark"></i></span>
            <span class="settings-item__text">
              <strong>Saved posts</strong>
              <small>Posts you bookmarked</small>
            </span>
            <i class="fas fa-chevron-right"></i>
          </a>
          <a href="/profile/upload" class="settings-item">
            <span class="settings-item__icon"><i class="fas fa-camera"></i></span>
            <span class="settings-item__text">
              <strong>Change profile photo</strong>
              <small>Update your avatar</small>
            </span>
            <i class="fas fa-chevron-right"></i>
          </a>
          <a href="/profile#bio" class="settings-item">
            <span class="settings-item__icon"><i class="fas fa-pen"></i></span>
            <span class="settings-item__text">
              <strong>Edit bio</strong>
              <small>On your profile page</small>
            </span>
            <i class="fas fa-chevron-right"></i>
          </a>
          <a href="/feed" class="settings-item">
            <span class="settings-item__icon"><i class="fas fa-house"></i></span>
            <span class="settings-item__text">
              <strong>Home feed</strong>
              <small>See posts from everyone</small>
            </span>
            <i class="fas fa-chevron-right"></i>
          </a>
          <a href="/messages" class="settings-item">
            <span class="settings-item__icon"><i class="far fa-comment-dots"></i></span>
            <span class="settings-item__text">
              <strong>Messages</strong>
              <small>Chat with friends</small>
            </span>
            <i class="fas fa-chevron-right"></i>
          </a>
          <a href="/explore" class="settings-item">
            <span class="settings-item__icon"><i class="fas fa-compass"></i></span>
            <span class="settings-item__text">
              <strong>Explore</strong>
              <small>Discover people & posts</small>
            </span>
            <i class="fas fa-chevron-right"></i>
          </a>
          <a href="/about" class="settings-item">
            <span class="settings-item__icon"><i class="fas fa-user-gear"></i></span>
            <span class="settings-item__text">
              <strong>Account Info</strong>
              <small>Email, Username, Age & Gender</small>
            </span>
            <i class="fas fa-chevron-right"></i>
          </a>
        </nav>

        <div class="settings-menu settings-menu--danger">
          <a href="/logout" class="settings-item settings-item--logout">
            <span class="settings-item__icon"><i class="fas fa-right-from-bracket"></i></span>
            <span class="settings-item__text">
              <strong>Log out</strong>
              <small>Sign out of SocialSphere</small>
            </span>
          </a>
          <form action="/profile/delete-account" method="POST" onsubmit="return confirm('Are you absolutely sure you want to permanently delete your account? This action cannot be undone.')" style="margin: 0; width: 100%;">
            <button type="submit" class="settings-item settings-item--logout" style="width: 100%; border: none; background: none; font: inherit; cursor: pointer; text-align: left; padding: 0.9rem 1rem;">
              <span class="settings-item__icon" style="background: #fee2e2; color: #dc2626;"><i class="fas fa-trash-can"></i></span>
              <span class="settings-item__text">
                <strong style="color: #dc2626;">Delete Account</strong>
                <small style="color: var(--text-muted);">Permanently erase all your data</small>
              </span>
            </button>
          </form>
        </div>
      </div>
    </div>

    <%- include('../partials/bottom-nav') %>
  </div>
  <script src="/javascripts/app.js"></script>
</body>
</html>
